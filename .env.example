# Muhasebe Bürosu — Ortam Değişkenleri Şablonu
# Bu dosyayı kopyalayıp .env olarak kaydedin ve değerleri doldurun:
#   copy .env.example .env

# Django Güvenlik
# Üretimde güçlü ve rastgele bir anahtar üretin:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-buraya-guclu-bir-anahtar-yazin

# Geliştirme modunda True, üretimde False
DEBUG=True

# E-posta Ayarları (Gmail için "Uygulama Şifresi" kullanın)
EMAIL_HOST_USER=ornek@gmail.com
EMAIL_HOST_PASSWORD=uygulama-sifresi-buraya

# Hatırlatma e-postalarının gönderileceği adresler (virgülle ayırın)
HATIRLATMA_ALICI=muhasebe@buro.com,patron@buro.com

# Firma Bilgileri (E-Fatura XML için — GİB'e gönderilecek zorunlu bilgiler)
FIRMA_ADI=Örnek Muhasebe Ltd. Şti.
FIRMA_VKN=1234567890
FIRMA_VERGI_DAIRESI=Kadıköy
FIRMA_ADRES=Bağdat Cad. No:1, Kadıköy / İstanbul
