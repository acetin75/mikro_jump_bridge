# Mikro Sync — Ortam Değişkenleri Şablonu
# Kopyalayın: copy .env.example .env
# Ardından .env içindeki değerleri doldurun.
# Bu dosya (.env.example) Git'e gönderilir; .env ASLA gönderilmez.

# -----------------------------------------------------------------------
# GÜVENLİK
# -----------------------------------------------------------------------
# Güçlü rastgele bir anahtar üretin:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=buraya-guclu-uretilmis-anahtar-yazin

# Geliştirme: True | Üretim: False
DEBUG=True

# Üretimde virgülle ayırın: 127.0.0.1,localhost,192.168.1.10
ALLOWED_HOSTS=127.0.0.1,localhost

# -----------------------------------------------------------------------
# ÜRETİM GÜVENLİK (DEBUG=False iken devreye girer)
# -----------------------------------------------------------------------
# CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8001
# SECURE_SSL_REDIRECT=False

# -----------------------------------------------------------------------
# CLOUDFLARE TUNNEL (isteğe bağlı — dışarıdan erişim için)
# -----------------------------------------------------------------------
# Her müşteriye Cloudflare Zero Trust panelinden benzersiz token verilir.
# Token alındıktan sonra aşağıdaki iki satırın başındaki # kaldırılır.
#
# Tunnel token'ı Cloudflare Zero Trust → Access → Tunnels → tunnel seç → Configure → Token
# TUNNEL_TOKEN=eyJhIjoiXXXXXXXXXXXXXXXXXXXXXXXXXXXXX...
#
# Cloudflare DNS'de bu subdomain'i tunnel'a yönlendirin.
# TUNNEL_HOSTNAME=firmaabc.mikrojumpbridge.com
